<Window x:Class="AiFun.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:aiFun="clr-namespace:AiFun"
        Title="MainWindow" Height="350" Width="525" WindowState="Maximized"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        >
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <ItemsControl ItemsSource="{Binding Ecosystem.AnimateObjects}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="aiFun:Animal">
                    <Canvas Width="10" Height="10">
                        <Canvas.RenderTransform>
                            <RotateTransform Angle="{Binding LookingAngle}" CenterX="5" CenterY="5"/>
                        </Canvas.RenderTransform>
                        <!-- Vision ray — extends from creature nose along heading -->
                        <Rectangle Canvas.Left="10" Canvas.Top="4.5"
                                   Width="{Binding VisionRayDisplayLength}" Height="1"
                                   Visibility="{Binding DataContext.ShowVisionRays, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource BoolToVis}}">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding VisionRayColor}"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <!-- Creature body — fill from genetic color, stroke from origin -->
                        <Polygon Points="0,0 10,5 0,10" StrokeThickness="1.5">
                            <Polygon.Fill>
                                <SolidColorBrush Color="{Binding BodyColor}"/>
                            </Polygon.Fill>
                            <Polygon.Stroke>
                                <SolidColorBrush Color="{Binding StrokeColor}"/>
                            </Polygon.Stroke>
                        </Polygon>
                        <!-- Forward marker (nose dot) -->
                        <Ellipse Canvas.Left="9" Canvas.Top="4" Width="2" Height="2" Fill="#FFE53935"/>
                    </Canvas>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas x:Name="TheCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></Canvas>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <ContentPresenter Content="{Binding}"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>

        <!-- Generation Progress Graph -->
        <aiFun:GenerationGraphControl x:Name="GenerationGraph"
            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8" Panel.ZIndex="10"/>

        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Padding="8" Background="#AAFFFFFF" CornerRadius="4" Panel.ZIndex="10">
            <StackPanel Width="280">
                <TextBlock FontWeight="Bold" Margin="0,0,0,6" Text="Simulation Controls"/>

                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <TextBlock Text="Generation"/>
                    <TextBlock Text="{Binding Ecosystem.GenerationCount}" HorizontalAlignment="Right"/>
                    <TextBlock Text="Alive"/>
                    <TextBlock Text="{Binding Ecosystem.AliveCount}" HorizontalAlignment="Right"/>
                    <TextBlock Text="Dead"/>
                    <TextBlock Text="{Binding Ecosystem.DeadCount}" HorizontalAlignment="Right"/>
                    <TextBlock Text="Pregnant"/>
                    <TextBlock Text="{Binding Ecosystem.PregnantCount}" HorizontalAlignment="Right"/>
                    <TextBlock Text="Avg Energy"/>
                    <TextBlock Text="{Binding Ecosystem.AverageEnergy, StringFormat={}{0:F0}}" HorizontalAlignment="Right"/>
                    <TextBlock Text="Avg Speed"/>
                    <TextBlock Text="{Binding Ecosystem.AverageSpeed, StringFormat={}{0:F2}}" HorizontalAlignment="Right"/>
                    <TextBlock Text="Tick (ms)"/>
                    <TextBlock Text="{Binding TickMilliseconds, StringFormat={}{0:F0}}" HorizontalAlignment="Right"/>
                </UniformGrid>

                <TextBlock Text="Tick Interval"/>
                <Slider Minimum="16" Maximum="200" Value="{Binding TickMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Steps Per Frame"/>
                <Slider Minimum="1" Maximum="500" Value="{Binding StepsPerFrame, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Initial Population"/>
                <Slider Minimum="10" Maximum="250" Value="{Binding Ecosystem.InitialPopulation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Elite Offspring"/>
                <Slider Minimum="0" Maximum="250" Value="{Binding Ecosystem.ElitePopulation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Random Offspring"/>
                <Slider Minimum="0" Maximum="250" Value="{Binding Ecosystem.RandomPopulation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Base Energy Drain"/>
                <Slider Minimum="10" Maximum="500" Value="{Binding Ecosystem.BaseEnergyDrainPerSecond, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Movement Cost"/>
                <Slider Minimum="1" Maximum="50" Value="{Binding Ecosystem.MovementEnergyCostMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Pregnancy (s)"/>
                <Slider Minimum="1" Maximum="20" Value="{Binding Ecosystem.PregnancyDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Corpse Decay (s)"/>
                <Slider Minimum="1" Maximum="30" Value="{Binding Ecosystem.CorpseDecaySeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Max Vision Distance"/>
                <Slider Minimum="10" Maximum="600" Value="{Binding Ecosystem.MaxVisionDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,6,0,0" Text="Vision Energy Cost"/>
                <Slider Minimum="0" Maximum="5" Value="{Binding Ecosystem.VisionEnergyCostMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsSnapToTickEnabled="False" SmallChange="0.1"/>

                <CheckBox Margin="0,8,0,0" Content="Show Vision Rays (V)"
                          IsChecked="{Binding ShowVisionRays, Mode=TwoWay}"/>

                <WrapPanel Margin="0,8,0,0">
                    <Button Content="Reset (F5)" Width="85" Margin="0,0,4,0" Click="OnResetClick"/>
                    <Button Content="Next Gen (G)" Width="95" Margin="0,0,4,0" Click="OnNextGenerationClick"/>
                    <Button Content="Pause/Resume (Space)" Width="130" Click="OnPauseResumeClick"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
